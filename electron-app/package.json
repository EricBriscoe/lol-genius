{
  "name": "lol-genius",
  "version": "1.0.0",
  "description": "League of Legends live win probability predictor",
  "main": "dist/main/main.js",
  "author": "Eric Briscoe",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/EricBriscoe/lol-genius.git",
    "directory": "electron-app"
  },
  "homepage": "https://github.com/EricBriscoe/lol-genius#readme",
  "bugs": {
    "url": "https://github.com/EricBriscoe/lol-genius/issues"
  },
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "start": "electron-vite preview",
    "package": "electron-builder",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "electron-log": "^5.4.3",
    "electron-updater": "^6.8.3",
    "lucide-react": "^0.577.0",
    "onnxruntime-node": "^1.22.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "recharts": "^3.8.0"
  },
  "devDependencies": {
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^5.1.4",
    "electron": "^40.0.0",
    "electron-builder": "^26.8.1",
    "electron-vite": "^5.0.0",
    "typescript": "~5.9.0",
    "vite": "^7.3.1",
    "vitest": "^4.0.18"
  },
  "build": {
    "appId": "com.ericbriscoe.lol-genius",
    "productName": "lol-genius",
    "directories": {
      "output": "dist-electron"
    },
    "win": {
      "target": "nsis",
      "icon": "assets/icon.ico"
    },
    "mac": {
      "target": "dmg",
      "icon": "assets/icon.png",
      "category": "public.app-category.games"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    },
    "publish": {
      "provider": "github",
      "owner": "EricBriscoe",
      "repo": "lol-genius"
    },
    "extraResources": [
      {
        "from": "models/",
        "to": "models/"
      },
      {
        "from": "sidecar/dist/",
        "to": "sidecar/",
        "filter": [
          "**/*"
        ]
      }
    ],
    "asarUnpack": [
      "**/node_modules/onnxruntime-node/**"
    ]
  }
}
